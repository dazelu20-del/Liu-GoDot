[connection signal="pressed" from="CenterContainer/MenuPanel/VBoxContainer/ResumeButton" to="." method="_on_resume_pressed"]
[connection signal="pressed" from="CenterContainer/MenuPanel/VBoxContainer/ReturnButton" to="." method="_on_return_to_menu_pressed"]
